<% content_for :navbar_text_label, "Carbomeals" %>
<% content_for :navbar_text_path, recipes_path %>

<div class="container py-4">
  <div class="card shadow-sm rounded-5 p-4 border-0">

    <div class="recipe-show-image rounded-4 mb-4" style="background-image: url('<%= @recipe.photo.attached? ? url_for(@recipe.photo) : Recipe::DEFAULT_IMAGE_URL %>');"></div>

    <h1 class="h-default mb-1"><%= @recipe.name %></h1>
    <p class="text-muted p-default mb-4"><%= @recipe.description %></p>

    <div class="d-flex gap-3 mb-4">
      <span class="gi-badge gi-<%= @recipe.gi_level %>">
        <i class="bi bi-droplet-fill"></i> IG <%= @recipe.indice_gly %>
      </span>
      <span class="carb-badge carb-<%= @recipe.gi_level %>">
        <i class="bi bi-lightning-charge-fill"></i> <%= @recipe.ratio_glucide %>g glucides/100g
      </span>
    </div>

    <% if @recipe.steps.present? %>
      <h3 class="h-default mb-3">Steps</h3>
      <div class="recipe-show-steps p-default mb-4">
        <% @recipe.steps.split(/(?=\d+\.)/).reject(&:blank?).each do |step| %>
          <% match = step.strip.match(/^(\d+)\.\s*(.*)/) %>
          <div class="step-item">
            <% if match %>
              <div class="step-number"><%= match[1] %></div>
              <div class="step-content"><%= match[2] %></div>
            <% else %>
              <div class="step-content"><%= step.strip %></div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @recipe.user == current_user %>
      <div class="recipe-show-actions mt-2 d-flex gap-2">
        <%= link_to edit_recipe_path(@recipe), class: "btn button-default rounded-5" do %>
          <i class="bi bi-pencil me-2"></i>Edit
        <% end %>
        <%= link_to recipe_path(@recipe),
            data: { turbo_method: :delete, turbo_confirm: "Delete this recipe?" },
            class: "btn btn-outline-danger rounded-5" do %>
          <i class="bi bi-trash me-2"></i>Delete
        <% end %>
      </div>
    <% end %>

  </div>
</div>
